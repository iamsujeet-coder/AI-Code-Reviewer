PORT=5000
# Optional (enables persistence)
MONGODB_URI=

# Which AI provider to use.
# - openai: OpenAI API compatible
# - huggingface: Hugging Face Inference API (token starts with hf_)
# - mock: always returns a mock review
AI_PROVIDER=openai

# OpenAI API key.
# If missing, the app will fallback to other providers or mock mode.
OPENAI_API_KEY=
# For OpenAI use: https://api.openai.com/v1
# For OpenRouter use (example): https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Hugging Face Inference API
HF_API_KEY=
# Default model. You can change this to a model you have access to.
HF_MODEL=openai/gpt-oss-120b:groq
# Base URL for HF Inference Providers (router).
# Use router because api-inference.huggingface.co is no longer supported.
HF_BASE_URL=https://router.huggingface.co/v1

